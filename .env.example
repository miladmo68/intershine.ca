# ----------------------------------------------------------------
# Intershine — server environment variables
# Copy this file to `.env` and fill in real values. Never commit .env.
# ----------------------------------------------------------------

# Port the Express server listens on (default: 3000)
PORT=3000

# Node environment (development | production)
NODE_ENV=development

# ---- SMTP (Nodemailer) ----
# Examples:
#   Gmail (use an App Password):
#     SMTP_HOST=smtp.gmail.com
#     SMTP_PORT=465
#     SMTP_SECURE=true
#   SendGrid:
#     SMTP_HOST=smtp.sendgrid.net
#     SMTP_PORT=587
#     SMTP_SECURE=false
#     SMTP_USER=apikey
#     SMTP_PASS=<your-sendgrid-api-key>
#   Mailgun:
#     SMTP_HOST=smtp.mailgun.org
#     SMTP_PORT=587
#     SMTP_SECURE=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# ---- Email addresses ----
# Where booking requests are delivered
MAIL_TO=info@intershine.ca

# The "From" address used on outgoing emails. Should match a domain
# you control / your SMTP provider allows (e.g. no-reply@intershine.ca).
MAIL_FROM=no-reply@intershine.ca
